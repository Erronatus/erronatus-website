---
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Layered Background -->
  <div class="absolute inset-0">
    <img src="/images/hero-bg.png" alt="" class="w-full h-full object-cover opacity-20" loading="eager" />
  </div>
  <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg)]/40 via-[var(--color-bg)]/70 to-[var(--color-bg)]"></div>
  <div class="hero-mesh"></div>
  <div class="grid-overlay absolute inset-0"></div>

  <!-- Extra ambient orb -->
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[1000px] rounded-full opacity-15"
    style="background: radial-gradient(circle, rgba(6, 182, 212, 0.12), transparent 60%); filter: blur(80px); animation: orb-float 16s ease-in-out infinite reverse;">
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-7xl section-padding w-full pt-32 pb-20">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-12 items-center">
      <!-- Left: Copy -->
      <div>
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full mb-10"
          style="background: rgba(139, 92, 246, 0.08); border: 1px solid rgba(139, 92, 246, 0.15); animation: fade-in 0.8s ease-out 0.2s both;">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-purple animate-pulse"></span>
          <span class="text-[11px] font-semibold tracking-[0.2em] uppercase" style="color: var(--color-accent-purple);">
            The AI Automation Framework
          </span>
        </div>

        <!-- Headline — dramatically large -->
        <h1 class="text-[3.2rem] sm:text-[4rem] md:text-[5rem] lg:text-[5.5rem] xl:text-[6.5rem] font-extrabold tracking-[-0.03em] leading-[0.92] mb-8"
          style="animation: fade-in 1s ease-out 0.4s both;">
          Your AI
          <br />
          Workforce
          <br />
          <span class="gradient-text">Starts Here</span>
        </h1>

        <!-- Subheadline -->
        <p class="max-w-lg text-lg md:text-xl leading-relaxed mb-10"
          style="color: var(--color-text-secondary); animation: fade-in 1s ease-out 0.7s both;">
          The Erronatus Blueprint teaches you to build autonomous AI systems that
          execute, analyze, and scale — while you focus on what matters.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-start gap-4"
          style="animation: fade-in 1s ease-out 1s both;">
          <a href="#blueprint" class="btn-primary gap-2">
            <span>Get The Blueprint</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="/blog" class="btn-secondary gap-2">
            <span>Read The Blog</span>
          </a>
        </div>

        <!-- Social proof -->
        <div class="mt-14 flex items-center gap-5"
          style="animation: fade-in 1s ease-out 1.3s both;">
          <div class="flex -space-x-2.5">
            {[1,2,3,4,5].map(i => (
              <div class="w-9 h-9 rounded-full border-2 flex items-center justify-center text-[10px] font-bold"
                style={`border-color: var(--color-bg); background: linear-gradient(135deg, hsl(${220 + i * 25}, 70%, 45%), hsl(${240 + i * 25}, 70%, 55%));`}>
                {['J','A','M','S','K'][i-1]}
              </div>
            ))}
          </div>
          <p class="text-sm" style="color: var(--color-text-muted);">
            Trusted by <span class="font-semibold" style="color: var(--color-text-secondary);">250+</span> automation builders
          </p>
        </div>
      </div>

      <!-- Right: Terminal Mockup -->
      <div class="lg:pl-6" style="animation: fade-in 1.2s ease-out 0.8s both;">
        <div class="terminal-window shadow-2xl" style="box-shadow: 0 40px 100px rgba(0,0,0,0.5), 0 0 80px rgba(139, 92, 246, 0.06);">
          <div class="terminal-titlebar">
            <div class="terminal-dot" style="background: #ff5f57;"></div>
            <div class="terminal-dot" style="background: #febc2e;"></div>
            <div class="terminal-dot" style="background: #28c840;"></div>
            <span class="ml-3 text-[11px]" style="color: var(--color-text-muted);">erronatus — terminal</span>
          </div>
          <div class="terminal-body text-[12px] md:text-[13px]">
            <div><span class="prompt">$</span> <span class="cmd">openclaw gateway start</span></div>
            <div class="mt-1"><span class="success">✓</span> Gateway online · port 18789</div>
            <div><span class="success">✓</span> Model: claude-sonnet-4</div>
            <div><span class="success">✓</span> Channel: telegram connected</div>
            <div class="mt-3"><span class="prompt">$</span> <span class="cmd">openclaw status</span></div>
            <div class="mt-1"><span class="dim">┌──────────────────────────────┐</span></div>
            <div><span class="dim">│</span> <span class="accent">APIs</span>      <span class="success">9/9 operational</span>  <span class="dim">│</span></div>
            <div><span class="dim">│</span> <span class="accent">Cron Jobs</span>  <span class="success">12 active</span>       <span class="dim">│</span></div>
            <div><span class="dim">│</span> <span class="accent">Memory</span>    <span class="success">47 files</span>        <span class="dim">│</span></div>
            <div><span class="dim">│</span> <span class="accent">Uptime</span>    <span style="color: var(--color-text-secondary);">14d 7h 23m</span>    <span class="dim">│</span></div>
            <div><span class="dim">│</span> <span class="accent">Cost</span>      <span style="color: var(--color-text-secondary);">$2.14 today</span>    <span class="dim">│</span></div>
            <div><span class="dim">└──────────────────────────────┘</span></div>
            <div class="mt-3"><span class="success">⚡</span> <span style="color: var(--color-text-secondary);">System fully autonomous.</span></div>
            <div class="mt-1 inline-flex items-center"><span class="prompt">$</span> <span class="w-2 h-4 ml-1 bg-accent-cyan/70 animate-pulse"></span></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2"
    style="animation: scroll-hint 2.5s ease-in-out infinite;">
    <span class="text-[9px] uppercase tracking-[0.3em] font-medium" style="color: var(--color-text-muted);">Scroll</span>
    <svg class="w-4 h-4" style="color: var(--color-text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
