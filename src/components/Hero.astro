---
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Layered Background -->
  <div class="absolute inset-0">
    <img src="/images/hero-bg.png" alt="" class="w-full h-full object-cover opacity-20" loading="eager" />
  </div>
  <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg)]/40 via-[var(--color-bg)]/70 to-[var(--color-bg)]"></div>
  <div class="hero-mesh"></div>
  <div class="grid-overlay absolute inset-0"></div>

  <!-- Ambient orb -->
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[1000px] rounded-full opacity-15"
    style="background: radial-gradient(circle, rgba(6, 182, 212, 0.12), transparent 60%); filter: blur(80px); animation: orb-float 16s ease-in-out infinite reverse;">
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-7xl section-padding w-full pt-32 pb-20">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-12 items-center">
      <!-- Left: Copy -->
      <div>
        <div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full mb-10"
          style="background: rgba(139, 92, 246, 0.08); border: 1px solid rgba(139, 92, 246, 0.15); animation: fade-in 0.8s ease-out 0.2s both;">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-purple animate-pulse"></span>
          <span class="text-[11px] font-semibold tracking-[0.2em] uppercase" style="color: var(--color-accent-purple);">
            The AI Automation Framework
          </span>
        </div>

        <h1 class="text-[3.2rem] sm:text-[4rem] md:text-[5rem] lg:text-[5.5rem] xl:text-[6.5rem] font-extrabold tracking-[-0.03em] leading-[0.92] mb-8"
          style="animation: fade-in 1s ease-out 0.4s both;">
          Your AI
          <br />
          Workforce
          <br />
          <span class="gradient-text">Starts Here</span>
        </h1>

        <p class="max-w-lg text-lg md:text-xl leading-relaxed mb-10"
          style="color: var(--color-text-secondary); animation: fade-in 1s ease-out 0.7s both;">
          The Erronatus Blueprint teaches you to build autonomous AI systems that
          execute, analyze, and scale — while you focus on what matters.
        </p>

        <div class="flex flex-col sm:flex-row items-start gap-4"
          style="animation: fade-in 1s ease-out 1s both;">
          <a href="#blueprint" class="btn-primary gap-2">
            <span>Get The Blueprint</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="/blog" class="btn-secondary gap-2">
            <span>Read The Blog</span>
          </a>
        </div>

        <div class="mt-14 flex items-center gap-5"
          style="animation: fade-in 1s ease-out 1.3s both;">
          <div class="flex -space-x-2.5">
            {[1,2,3,4,5].map(i => (
              <div class="w-9 h-9 rounded-full border-2 flex items-center justify-center text-[10px] font-bold"
                style={`border-color: var(--color-bg); background: linear-gradient(135deg, hsl(${220 + i * 25}, 70%, 45%), hsl(${240 + i * 25}, 70%, 55%));`}>
                {['J','A','M','S','K'][i-1]}
              </div>
            ))}
          </div>
          <p class="text-sm" style="color: var(--color-text-muted);">
            Trusted by <span class="font-semibold" style="color: var(--color-text-secondary);">250+</span> automation builders
          </p>
        </div>
      </div>

      <!-- Right: Animated Terminal -->
      <div class="lg:pl-6" style="animation: fade-in 1.2s ease-out 0.8s both;">
        <div class="terminal-window shadow-2xl" style="box-shadow: 0 40px 100px rgba(0,0,0,0.5), 0 0 80px rgba(139, 92, 246, 0.06);">
          <div class="terminal-titlebar">
            <div class="terminal-dot" style="background: #ff5f57;"></div>
            <div class="terminal-dot" style="background: #febc2e;"></div>
            <div class="terminal-dot" style="background: #28c840;"></div>
            <span class="ml-3 text-[11px]" style="color: var(--color-text-muted);">erronatus — workflow</span>
          </div>
          <div id="terminal-body" class="terminal-body text-[12px] md:text-[13px] min-h-[320px]">
            <!-- Animated content injected by JS -->
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2"
    style="animation: scroll-hint 2.5s ease-in-out infinite;">
    <span class="text-[9px] uppercase tracking-[0.3em] font-medium" style="color: var(--color-text-muted);">Scroll</span>
    <svg class="w-4 h-4" style="color: var(--color-text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script is:inline>
(function() {
  const workflows = [
    {
      title: 'Morning Briefing',
      lines: [
        { type: 'cmd', text: '$ openclaw cron run morning-briefing' },
        { type: 'info', text: '⏳ Running workflow...' },
        { type: 'step', text: '→ Fetching top headlines from NewsAPI...' },
        { type: 'ok', text: '✓ 5 articles pulled' },
        { type: 'step', text: '→ Checking AAPL, TSLA, NVDA prices...' },
        { type: 'ok', text: '✓ AAPL $214.30 (+1.2%) · TSLA $188.40 (-0.8%)' },
        { type: 'step', text: '→ Summarizing with DeepSeek V3...' },
        { type: 'ok', text: '✓ Briefing generated · cost: $0.003' },
        { type: 'step', text: '→ Delivering via Telegram...' },
        { type: 'ok', text: '✓ Sent to @jacksontrades' },
        { type: 'done', text: '⚡ Workflow complete in 4.2s' },
      ]
    },
    {
      title: 'Lead Generation',
      lines: [
        { type: 'cmd', text: '$ openclaw run lead-scraper --target "ai startups"' },
        { type: 'info', text: '⏳ Initializing scraper...' },
        { type: 'step', text: '→ Scanning 12 directories...' },
        { type: 'ok', text: '✓ Found 847 companies' },
        { type: 'step', text: '→ Filtering by criteria (Series A, 10-50 employees)...' },
        { type: 'ok', text: '✓ 38 qualified leads' },
        { type: 'step', text: '→ Enriching contacts via API...' },
        { type: 'ok', text: '✓ 34 emails verified' },
        { type: 'step', text: '→ Scoring & ranking leads...' },
        { type: 'ok', text: '✓ Top 10 exported to Supabase' },
        { type: 'step', text: '→ Drafting outreach sequence...' },
        { type: 'ok', text: '✓ 3-email sequence queued via Resend' },
        { type: 'done', text: '⚡ Pipeline complete · 34 leads ready' },
      ]
    },
    {
      title: 'Market Monitor',
      lines: [
        { type: 'cmd', text: '$ openclaw cron run market-scan' },
        { type: 'info', text: '⏳ Scanning watchlist...' },
        { type: 'step', text: '→ Pulling RSI for 8 symbols...' },
        { type: 'ok', text: '✓ All indicators loaded' },
        { type: 'dim', text: '  AAPL  RSI 52.3  ——— neutral' },
        { type: 'dim', text: '  TSLA  RSI 31.2  ——— approaching oversold' },
        { type: 'warn', text: '  NVDA  RSI 28.4  ⚠️  OVERSOLD' },
        { type: 'step', text: '→ Checking news sentiment for NVDA...' },
        { type: 'ok', text: '✓ No negative catalysts found' },
        { type: 'step', text: '→ Generating alert...' },
        { type: 'ok', text: '✓ Alert sent: "NVDA RSI 28.4 — potential bounce"' },
        { type: 'step', text: '→ Logging to trade journal...' },
        { type: 'ok', text: '✓ Entry logged in Supabase' },
        { type: 'done', text: '⚡ Scan complete · 1 alert fired · cost: $0.002' },
      ]
    },
  ];

  const colors = {
    cmd: 'color: #06b6d4; font-weight: 600;',
    info: 'color: #94949e;',
    step: 'color: #94949e;',
    ok: 'color: #22c55e;',
    warn: 'color: #f59e0b;',
    dim: 'color: #5a5a66;',
    done: 'color: #8b5cf6; font-weight: 600;',
  };

  let currentWorkflow = 0;

  function getTerminal() {
    return document.getElementById('terminal-body');
  }

  function sleep(ms) {
    return new Promise(r => setTimeout(r, ms));
  }

  async function typeLine(terminal, line) {
    const div = document.createElement('div');
    div.style.cssText = colors[line.type] || '';
    div.style.opacity = '0';
    div.style.transform = 'translateY(4px)';
    div.style.transition = 'opacity 0.2s, transform 0.2s';
    terminal.appendChild(div);
    terminal.scrollTop = terminal.scrollHeight;

    // Type out command lines character by character
    if (line.type === 'cmd') {
      div.style.opacity = '1';
      div.style.transform = 'translateY(0)';
      for (let i = 0; i < line.text.length; i++) {
        div.textContent = line.text.substring(0, i + 1);
        await sleep(18 + Math.random() * 12);
      }
    } else {
      div.textContent = line.text;
      // Pop in
      requestAnimationFrame(() => {
        div.style.opacity = '1';
        div.style.transform = 'translateY(0)';
      });
    }
  }

  async function runWorkflow() {
    const terminal = getTerminal();
    if (!terminal) return;

    const wf = workflows[currentWorkflow];
    terminal.innerHTML = '';

    for (const line of wf.lines) {
      await typeLine(terminal, line);
      if (line.type === 'cmd') await sleep(600);
      else if (line.type === 'done') await sleep(0);
      else await sleep(250 + Math.random() * 150);
    }

    // Add blinking cursor
    const cursor = document.createElement('div');
    cursor.style.cssText = 'margin-top: 8px; color: #06b6d4;';
    cursor.innerHTML = '$ <span style="display:inline-block;width:8px;height:16px;background:rgba(6,182,212,0.7);animation:blink 1s step-end infinite;vertical-align:middle;"></span>';
    terminal.appendChild(cursor);

    // Hold for 3 seconds then move to next
    await sleep(3000);
    currentWorkflow = (currentWorkflow + 1) % workflows.length;
    runWorkflow();
  }

  // Start after page load with a slight delay
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => setTimeout(runWorkflow, 1500));
  } else {
    setTimeout(runWorkflow, 1500);
  }
})();
</script>

<style is:global>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>
