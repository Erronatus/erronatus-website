---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Animated Background -->
  <div class="hero-mesh"></div>
  <div class="grid-overlay absolute inset-0"></div>

  <!-- Third floating orb -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full opacity-20 animate-pulse-glow"
    style="background: radial-gradient(circle, rgba(6, 182, 212, 0.15), transparent 60%);">
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-6xl section-padding text-center">
    <!-- Eyebrow -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-8 animate-fade-in"
      style="background: rgba(139, 92, 246, 0.1); border: 1px solid rgba(139, 92, 246, 0.2);">
      <span class="w-1.5 h-1.5 rounded-full bg-accent-purple animate-pulse"></span>
      <span class="text-xs font-semibold tracking-widest uppercase" style="color: var(--color-accent-purple);">
        AI Automation Framework
      </span>
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold tracking-tight leading-[0.95] mb-8"
      style="animation: fade-in-up 1s ease-out 0.2s both;">
      Your AI Workforce
      <br />
      <span class="gradient-text">Starts Here</span>
    </h1>

    <!-- Subheadline -->
    <p class="max-w-2xl mx-auto text-lg md:text-xl leading-relaxed mb-12"
      style="color: var(--color-text-secondary); animation: fade-in-up 1s ease-out 0.5s both;">
      The Erronatus Blueprint teaches you to build autonomous AI systems that
      execute, analyze, and scale — while you focus on what matters.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4"
      style="animation: fade-in-up 1s ease-out 0.8s both;">
      <a href="#blueprint" class="btn-primary gap-2">
        <span>Get The Blueprint</span>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a href="/blog" class="btn-secondary gap-2">
        <span>Read The Blog</span>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
      </a>
    </div>

    <!-- Social proof hint -->
    <div class="mt-16 flex items-center justify-center gap-6"
      style="animation: fade-in 1s ease-out 1.2s both;">
      <div class="flex -space-x-2">
        {[1,2,3,4,5].map(i => (
          <div class="w-8 h-8 rounded-full border-2 flex items-center justify-center text-xs font-bold"
            style={`border-color: var(--color-bg); background: linear-gradient(135deg, hsl(${220 + i * 25}, 70%, 50%), hsl(${240 + i * 25}, 70%, 60%));`}>
            {['J','A','M','S','K'][i-1]}
          </div>
        ))}
      </div>
      <p class="text-sm" style="color: var(--color-text-muted);">
        Trusted by <span class="font-semibold" style="color: var(--color-text-secondary);">1,200+</span> automation builders
      </p>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-scroll-hint">
    <span class="text-[10px] uppercase tracking-[0.25em] font-medium" style="color: var(--color-text-muted);">Scroll</span>
    <svg class="w-4 h-4" style="color: var(--color-text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
