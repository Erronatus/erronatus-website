---
const currentYear = new Date().getFullYear();

const links = {
  product: [
    { label: 'The Blueprint', href: '/#blueprint' },
    { label: 'Crontrepreneur', href: '/crontrepreneur' },
    { label: 'Blog', href: '/blog' },
  ],
  legal: [
    { label: 'Privacy Policy', href: '/privacy' },
    { label: 'Terms of Service', href: '/terms' },
    { label: 'Contact', href: '/contact' },
  ],
  resources: [
    { label: 'OpenClaw Docs', href: 'https://docs.openclaw.ai' },
    { label: 'GitHub', href: 'https://github.com/openclaw/openclaw' },
    { label: 'Community', href: 'https://discord.com/invite/clawd' },
  ],
};
---

<footer class="relative overflow-hidden" style="border-top: 1px solid var(--color-border);">
  <!-- Ambient glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[400px] h-[1px] opacity-40"
    style="background: var(--gradient-primary); filter: blur(2px);"></div>

  <div class="section-padding py-16 md:py-20">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-12 md:gap-8">
        <!-- Brand -->
        <div class="col-span-2 md:col-span-1">
          <a href="/" class="inline-flex items-center gap-2.5 mb-4 group">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center transition-transform duration-300 group-hover:scale-110" style="background: var(--gradient-primary);">
              <span class="text-white font-extrabold text-sm">E</span>
            </div>
            <span class="text-lg font-bold tracking-tight">Erronatus</span>
          </a>
          <p class="text-sm leading-relaxed mt-3 max-w-xs" style="color: var(--color-text-muted);">
            AI automation systems that work while you don't.
          </p>
        </div>

        <!-- Product -->
        <div>
          <h4 class="text-xs font-semibold tracking-[0.2em] uppercase mb-5" style="color: var(--color-text-muted);">Product</h4>
          <ul class="space-y-3">
            {links.product.map(link => (
              <li>
                <a href={link.href} class="text-sm link-hover transition-colors duration-200 hover:text-white" style="color: var(--color-text-secondary);">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h4 class="text-xs font-semibold tracking-[0.2em] uppercase mb-5" style="color: var(--color-text-muted);">Legal</h4>
          <ul class="space-y-3">
            {links.legal.map(link => (
              <li>
                <a href={link.href} class="text-sm link-hover transition-colors duration-200 hover:text-white" style="color: var(--color-text-secondary);">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Resources -->
        <div>
          <h4 class="text-xs font-semibold tracking-[0.2em] uppercase mb-5" style="color: var(--color-text-muted);">Resources</h4>
          <ul class="space-y-3">
            {links.resources.map(link => (
              <li>
                <a href={link.href} class="text-sm link-hover transition-colors duration-200 hover:text-white" style="color: var(--color-text-secondary);" target="_blank" rel="noopener noreferrer">
                  <span class="inline-flex items-center gap-1.5">
                    {link.label}
                    <svg class="w-3 h-3 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Bottom -->
      <div class="mt-16 pt-8 flex flex-col md:flex-row items-center justify-between gap-4"
        style="border-top: 1px solid var(--color-border);">
        <p class="text-xs" style="color: var(--color-text-muted);">
          &copy; {currentYear} Erronatus. All rights reserved.
        </p>
        <div class="flex items-center gap-4">
          <span class="text-xs" style="color: var(--color-text-muted);">
            30-day money-back guarantee on all purchases.
          </span>
        </div>
      </div>
    </div>
  </div>
</footer>
