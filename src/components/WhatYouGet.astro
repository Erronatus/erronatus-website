---
import CheckoutButton from './CheckoutButton.astro';

const personalFeatures = [
  'Complete OpenClaw setup guide',
  'AI engine configuration & model selection',
  'Document analysis & summarization',
  'Daily task automation & scheduling',
  'Calendar & schedule optimization',
  'Personal memory system setup',
  'Telegram/Discord command interface',
  'Note-taking & organization workflows',
  'Deployment to Vercel',
];

const businessFeatures = [
  'Everything in Personal Edition',
  'Multi-engine routing (auto cost optimization)',
  'Market trend analysis framework',
  'Competitor & industry research automation',
  'Startup validation & planning tools',
  'Full 14-API toolchain integration',
  'Business metrics dashboards',
  'Client report generation',
  'Content & SEO automation',
  'Priority updates for 12 months',
];

const enterpriseFeatures = [
  'Everything in Business Edition',
  'Pre-built AI workspace (install & run)',
  'Web scraping & data extraction engine',
  'Automated lead generation pipelines',
  'Email outreach automation (Resend)',
  'Cron job library (50+ templates)',
  'Trading bot scaffold (Alpaca + RSI)',
  'Stripe payment integration',
  'One-command install script (Win/Mac/Linux)',
  'Complete .env template + credential vault',
  'Custom skill development framework',
  '24/7 VPS deployment guide',
  '90-day priority support via Telegram',
];

const PERSONAL_PRICE_ID = 'price_1T8qvXQ9JjxqCgrLVg4fX68s';
const BUSINESS_PRICE_ID = 'price_1T8qvgQ9JjxqCgrLsOtK5e15';
const ENTERPRISE_PRICE_ID = 'price_1T8qvgQ9JjxqCgrL5G6PpwIv';
---

<section id="blueprint" class="section-spacing section-padding relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 grid-overlay"></div>
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full opacity-10"
    style="background: radial-gradient(circle, var(--color-accent-blue), transparent 60%); filter: blur(100px);">
  </div>

  <div class="mx-auto max-w-7xl relative">
    <!-- Section Header -->
    <div class="text-center mb-20 reveal">
      <span class="text-xs font-semibold tracking-[0.3em] uppercase" style="color: var(--color-accent-cyan);">
        The Blueprint
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mt-4 mb-6">
        Choose Your
        <span class="gradient-text">Level of Automation</span>
      </h2>
      <p class="max-w-2xl mx-auto text-lg" style="color: var(--color-text-secondary);">
        Three tiers. One mission. Build AI systems that work while you don't.
      </p>
    </div>

    <!-- Product Mockup + Cards Layout -->
    <div class="grid lg:grid-cols-12 gap-8 items-start">

      <!-- Floating Mockup -->
      <div class="lg:col-span-3 flex justify-center reveal-left">
        <div class="relative">
          <div class="w-56 md:w-64 animate-float">
            <div class="aspect-[3/4] rounded-xl overflow-hidden shadow-2xl"
              style="background: linear-gradient(160deg, #111 0%, #1a1410 50%, #161210 100%); border: 1px solid rgba(212, 132, 58, 0.1);">
              <div class="p-6 h-full flex flex-col justify-between">
                <div>
                  <div class="w-8 h-8 rounded-lg mb-4 flex items-center justify-center"
                    style="background: var(--gradient-primary);">
                    <span class="text-white font-extrabold text-sm">E</span>
                  </div>
                  <div class="h-1 w-16 rounded mb-2" style="background: var(--gradient-primary); opacity: 0.6;"></div>
                  <div class="h-0.5 w-24 rounded mb-1" style="background: rgba(255,255,255,0.1);"></div>
                  <div class="h-0.5 w-20 rounded" style="background: rgba(255,255,255,0.06);"></div>
                </div>
                <div class="space-y-2">
                  <div class="text-[9px] font-semibold tracking-widest uppercase" style="color: var(--color-accent-cyan); opacity: 0.7;">
                    The Blueprint
                  </div>
                  <h3 class="text-base font-extrabold leading-tight" style="color: #fff;">
                    The Erronatus<br/>Blueprint
                  </h3>
                  <p class="text-[8px] leading-relaxed" style="color: rgba(255,255,255,0.4);">
                    AI Automation with OpenClaw
                  </p>
                </div>
                <div class="flex items-center gap-2">
                  <div class="h-px flex-1" style="background: rgba(255,255,255,0.1);"></div>
                  <span class="text-[7px] tracking-widest uppercase" style="color: rgba(255,255,255,0.3);">2026</span>
                </div>
              </div>
            </div>
          </div>
          <div class="absolute -inset-4 rounded-2xl opacity-20 -z-10"
            style="background: var(--gradient-primary); filter: blur(40px);">
          </div>
        </div>
      </div>

      <!-- Three Pricing Cards -->
      <div class="lg:col-span-9 grid md:grid-cols-3 gap-6">

        <!-- Personal -->
        <div class="glass-card glass-card-hover rounded-2xl p-7 flex flex-col reveal" style="transition-delay: 0.1s;">
          <div class="mb-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-lg">📋</span>
              <span class="text-xs font-semibold tracking-widest uppercase" style="color: var(--color-text-muted);">Personal</span>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-extrabold">$47</span>
              <span class="text-xs" style="color: var(--color-text-muted);">one-time</span>
            </div>
          </div>

          <p class="text-sm mb-6 leading-relaxed" style="color: var(--color-text-secondary);">
            Your AI-powered personal assistant. Organize your life, automate daily tasks, and never forget anything again.
          </p>

          <ul class="space-y-2.5 mb-8 flex-1">
            {personalFeatures.map(f => (
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: var(--color-accent-blue);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-xs leading-relaxed" style="color: var(--color-text-secondary);">{f}</span>
              </li>
            ))}
          </ul>

          <CheckoutButton
            priceId={PERSONAL_PRICE_ID}
            edition="personal"
            label="Get Personal"
            variant="secondary"
          />
        </div>

        <!-- Business -->
        <div class="relative rounded-2xl p-7 flex flex-col reveal gradient-border" style="transition-delay: 0.2s; background: var(--color-surface);">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-white"
            style="background: var(--gradient-primary);">
            Most Popular
          </div>

          <div class="mb-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-lg">🚀</span>
              <span class="text-xs font-semibold tracking-widest uppercase" style="color: var(--color-accent-purple);">Business</span>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-extrabold">$97</span>
              <span class="text-xs" style="color: var(--color-text-muted);">one-time</span>
            </div>
          </div>

          <p class="text-sm mb-6 leading-relaxed" style="color: var(--color-text-secondary);">
            AI-powered business intelligence. Market analysis, competitor research, and automation for serious operators.
          </p>

          <ul class="space-y-2.5 mb-8 flex-1">
            {businessFeatures.map(f => (
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: var(--color-accent-purple);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-xs leading-relaxed" style="color: var(--color-text-secondary);">{f}</span>
              </li>
            ))}
          </ul>

          <CheckoutButton
            priceId={BUSINESS_PRICE_ID}
            edition="business"
            label="Get Business"
            variant="primary"
          />
        </div>

        <!-- Enterprise -->
        <div class="relative rounded-2xl p-7 flex flex-col reveal" style="transition-delay: 0.3s; background: linear-gradient(160deg, rgba(17,17,17,0.95) 0%, rgba(30,20,12,0.95) 50%, rgba(20,15,10,0.95) 100%); border: 1px solid rgba(212, 168, 83, 0.3);">
          <!-- Golden badge -->
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-black"
            style="background: linear-gradient(135deg, #f59e0b, #fbbf24);">
            ⚡ The Golden Ticket
          </div>

          <div class="mb-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-lg">👑</span>
              <span class="text-xs font-semibold tracking-widest uppercase" style="color: #f59e0b;">Enterprise</span>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-extrabold" style="background: linear-gradient(135deg, #f59e0b, #fbbf24); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">$299</span>
              <span class="text-xs" style="color: var(--color-text-muted);">one-time</span>
            </div>
          </div>

          <p class="text-sm mb-6 leading-relaxed" style="color: var(--color-text-secondary);">
            The complete autonomous system. Pre-built, pre-configured, ready to deploy. Scraping, lead gen, email outreach, trading — all automated.
          </p>

          <ul class="space-y-2.5 mb-8 flex-1">
            {enterpriseFeatures.map(f => (
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: #f59e0b;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-xs leading-relaxed" style="color: var(--color-text-secondary);">{f}</span>
              </li>
            ))}
          </ul>

          <CheckoutButton
            priceId={ENTERPRISE_PRICE_ID}
            edition="enterprise"
            label="Get Enterprise"
            variant="primary"
          />
        </div>
      </div>
    </div>

    <!-- Guarantee -->
    <div class="mt-16 text-center reveal">
      <div class="inline-flex items-center gap-3 px-6 py-3 rounded-full glass-card">
        <svg class="w-5 h-5" style="color: var(--color-accent-cyan);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span class="text-sm font-medium" style="color: var(--color-text-secondary);">
          30-day money-back guarantee. No questions asked.
        </span>
      </div>
    </div>
  </div>
</section>
