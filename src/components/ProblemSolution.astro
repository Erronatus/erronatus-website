---
---

<section class="section-spacing section-padding relative overflow-hidden">
  <!-- Background accent -->
  <div class="absolute top-0 right-0 w-96 h-96 rounded-full opacity-8 pointer-events-none"
    style="background: radial-gradient(circle, var(--color-accent-blue), transparent 70%); filter: blur(100px);"></div>

  <div class="mx-auto max-w-6xl relative">
    <!-- Section Label -->
    <div class="reveal mb-4">
      <span class="text-xs font-semibold tracking-[0.3em] uppercase" style="color: var(--color-accent-cyan);">
        The Reality
      </span>
    </div>

    <!-- Two columns -->
    <div class="grid md:grid-cols-2 gap-16 lg:gap-24 items-start">
      <!-- Problem -->
      <div class="reveal-left">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight leading-tight mb-8">
          You're Still Doing
          <br />
          <span style="color: var(--color-text-muted);">Everything Manually</span>
        </h2>

        <div class="space-y-5">
          {[
            { icon: '⏱', text: 'Hours wasted on repetitive tasks that AI can execute in seconds' },
            { icon: '🔌', text: 'Dozens of disconnected tools with no automation between them' },
            { icon: '📊', text: 'Market data you never check because there\'s no system watching for you' },
            { icon: '🧠', text: 'Knowledge trapped in your head instead of documented in persistent memory' },
          ].map((item, i) => (
            <div class="problem-item flex gap-4 items-start p-4 -mx-4 rounded-xl transition-all duration-300 hover:bg-white/[0.02]"
              style={`transition-delay: ${i * 0.05}s;`}>
              <span class="text-xl mt-0.5 flex-shrink-0">{item.icon}</span>
              <p class="text-base leading-relaxed" style="color: var(--color-text-secondary);">
                {item.text}
              </p>
            </div>
          ))}
        </div>

        <div class="mt-10 h-px w-full" style="background: linear-gradient(to right, var(--color-border), transparent);"></div>

        <p class="mt-6 text-sm font-medium italic" style="color: var(--color-text-muted);">
          Every hour you spend on tasks AI should handle is an hour you're not building, scaling, or thinking.
        </p>
      </div>

      <!-- Solution -->
      <div class="reveal-right">
        <div class="glass-card glass-card-hover rounded-2xl p-8 md:p-10">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6"
            style="background: rgba(212, 132, 58, 0.08); border: 1px solid rgba(212, 132, 58, 0.15);">
            <span class="w-1.5 h-1.5 rounded-full" style="background: var(--color-accent-blue);"></span>
            <span class="text-xs font-semibold tracking-widest uppercase" style="color: var(--color-accent-blue);">
              The Solution
            </span>
          </div>

          <h3 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-6">
            Build Once.
            <br />
            <span class="gradient-text">Automate Forever.</span>
          </h3>

          <p class="text-base leading-relaxed mb-8" style="color: var(--color-text-secondary);">
            The Erronatus Blueprint is a comprehensive system for building your personal AI workforce.
            Configure once, deploy everywhere. Your AI handles monitoring, execution, analysis, and
            communication — autonomously.
          </p>

          <div class="space-y-4">
            {[
              'Multi-engine AI routing that picks the right model for every task',
              '14+ API integrations in a single reusable toolchain',
              'Persistent memory systems so your AI learns and remembers',
              'Cron-powered automation that works while you sleep',
              'Production deployment on your own infrastructure',
            ].map((item, i) => (
              <div class="flex items-start gap-3 group/item">
                <svg class="w-5 h-5 mt-0.5 flex-shrink-0 transition-transform duration-300 group-hover/item:scale-110" style="color: var(--color-accent-blue);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm" style="color: var(--color-text-secondary);">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
