---
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<section class="section-spacing section-padding relative overflow-hidden">
  <div class="mx-auto max-w-6xl">
    <div class="flex items-end justify-between mb-16 reveal">
      <div>
        <span class="text-xs font-semibold tracking-[0.3em] uppercase" style="color: var(--color-accent-cyan);">
          From the Blog
        </span>
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight mt-4">
          Insights &
          <span class="gradient-text">Playbooks</span>
        </h2>
      </div>
      <a href="/blog" class="hidden sm:inline-flex items-center gap-2 text-sm font-medium link-hover transition-colors duration-300 hover:text-white" style="color: var(--color-text-secondary);">
        View all posts
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post, i) => (
        <a href={`/blog/${post.slug}`}
          class="blog-card glass-card rounded-2xl overflow-hidden group reveal"
          style={`transition-delay: ${i * 0.1}s;`}>
          <!-- Image -->
          <div class="aspect-[16/9] relative overflow-hidden">
            {post.data.image ? (
              <img src={post.data.image} alt={post.data.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy" />
            ) : (
              <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-105"
                style={`background: linear-gradient(135deg, hsl(${25 + i * 10}, 40%, 12%), hsl(${30 + i * 12}, 45%, 18%));`} />
            )}
            <!-- Category Tag -->
            <div class="absolute top-4 left-4">
              <span class="px-3 py-1 rounded-full text-[10px] font-semibold tracking-widest uppercase text-white"
                style="background: rgba(212, 132, 58, 0.8); backdrop-filter: blur(8px);">
                {post.data.category}
              </span>
            </div>
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg)] via-transparent to-transparent opacity-0 group-hover:opacity-60 transition-opacity duration-500"></div>
          </div>

          <div class="p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs" style="color: var(--color-text-muted);">{post.data.date}</span>
              <span class="w-1 h-1 rounded-full" style="background: var(--color-text-muted);"></span>
              <span class="text-xs" style="color: var(--color-text-muted);">{post.data.readTime}</span>
            </div>
            <h3 class="text-lg font-bold mb-3 transition-colors duration-300 leading-snug group-hover:text-[var(--color-accent-blue)]">
              {post.data.title}
            </h3>
            <p class="text-sm leading-relaxed line-clamp-3" style="color: var(--color-text-secondary);">
              {post.data.excerpt}
            </p>
            <!-- Read more indicator -->
            <div class="mt-4 flex items-center gap-1.5 text-xs font-semibold tracking-wider uppercase opacity-0 -translate-y-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0" style="color: var(--color-accent-blue);">
              Read More
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Mobile view all link -->
    <div class="sm:hidden text-center mt-10 reveal">
      <a href="/blog" class="btn-secondary">View All Posts</a>
    </div>
  </div>
</section>

<style>
  .blog-card {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .blog-card:hover {
    border-color: rgba(212, 132, 58, 0.2);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.3);
    transform: translateY(-4px);
  }
</style>
