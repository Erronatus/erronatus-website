---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<section class="section-spacing section-padding relative overflow-hidden">
  <div class="mx-auto max-w-6xl">
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 reveal">
      <div>
        <span class="text-xs font-semibold tracking-[0.3em] uppercase" style="color: var(--color-accent-cyan);">
          The Blog
        </span>
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight mt-4">
          Insights &
          <span class="gradient-text">Playbooks</span>
        </h2>
      </div>
      <a href="/blog" class="btn-secondary mt-6 md:mt-0 self-start md:self-auto">
        View All Posts
      </a>
    </div>

    <!-- Blog Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post, i) => (
        <a href={`/blog/${post.slug}`}
          class="glass-card glass-card-hover rounded-2xl overflow-hidden group reveal"
          style={`transition-delay: ${i * 0.1}s;`}>
          <!-- Image placeholder -->
          <div class="aspect-[16/9] relative overflow-hidden">
            <div class="absolute inset-0 transition-transform duration-500 group-hover:scale-105"
              style={`background: linear-gradient(135deg, hsl(${220 + i * 30}, 60%, 15%), hsl(${240 + i * 30}, 60%, 25%));`}>
              <div class="absolute inset-0 flex items-center justify-center">
                <svg class="w-12 h-12 opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              </div>
            </div>
            <!-- Category Tag -->
            <div class="absolute top-4 left-4">
              <span class="px-3 py-1 rounded-full text-[10px] font-semibold tracking-widest uppercase text-white"
                style="background: rgba(139, 92, 246, 0.8); backdrop-filter: blur(8px);">
                {post.data.category}
              </span>
            </div>
          </div>

          <!-- Content -->
          <div class="p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs" style="color: var(--color-text-muted);">{post.data.date}</span>
              <span class="w-1 h-1 rounded-full" style="background: var(--color-text-muted);"></span>
              <span class="text-xs" style="color: var(--color-text-muted);">{post.data.readTime}</span>
            </div>
            <h3 class="text-lg font-bold mb-2 transition-colors duration-300 group-hover:text-accent-purple">
              {post.data.title}
            </h3>
            <p class="text-sm leading-relaxed line-clamp-2" style="color: var(--color-text-secondary);">
              {post.data.excerpt}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
