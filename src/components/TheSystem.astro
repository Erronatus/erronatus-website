---
const steps = [
  {
    num: '01',
    title: 'Infrastructure',
    description: 'Deploy OpenClaw on your machine. Configure your AI gateway, set up Telegram or Discord as your command interface, and establish the foundation for autonomous operations.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008V17.25zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008V17.25zm0-6h.008v.008h-.008v-.008z"/></svg>`,
  },
  {
    num: '02',
    title: 'Engine Routing',
    description: 'Configure multi-model AI routing. Free models for simple tasks, mid-tier for coding, premium for strategic thinking. Your system automatically picks the cheapest capable engine.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>`,
  },
  {
    num: '03',
    title: 'API Integration',
    description: 'Connect 14+ services into a single reusable toolchain. Trading APIs, databases, deployment platforms, email systems, and analytics — all wired up and ready to automate.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z"/></svg>`,
  },
  {
    num: '04',
    title: 'Memory Systems',
    description: 'Give your AI persistent memory. Daily logs, long-term memory files, credential vaults, and context management — your AI remembers everything across sessions.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/></svg>`,
  },
  {
    num: '05',
    title: 'Automation',
    description: 'Build cron jobs, heartbeat monitors, and autonomous workflows. Your AI checks emails, watches markets, sends alerts, and executes tasks — on schedule, without supervision.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
  },
];
---

<section id="system" class="section-spacing section-padding relative overflow-hidden">
  <div class="mx-auto max-w-6xl relative">
    <!-- Section Header -->
    <div class="text-center mb-20 reveal">
      <span class="text-xs font-semibold tracking-[0.3em] uppercase" style="color: var(--color-accent-cyan);">
        The Framework
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mt-4 mb-6">
        Five Layers.
        <br />
        <span class="gradient-text">One Autonomous System.</span>
      </h2>
      <p class="max-w-2xl mx-auto text-lg" style="color: var(--color-text-secondary);">
        Each chapter builds on the last. By the end, you have a fully operational AI workforce
        running on your own infrastructure.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative">
      <!-- Vertical line (desktop) -->
      <div class="hidden lg:block absolute left-[3.25rem] top-0 bottom-0 w-px"
        style="background: linear-gradient(to bottom, var(--color-border), var(--color-accent-purple), var(--color-border));">
      </div>

      <div class="space-y-6 lg:space-y-0">
        {steps.map((step, i) => (
          <div class="reveal lg:flex items-start gap-10 lg:py-12" style={`transition-delay: ${i * 0.1}s;`}>
            <!-- Number -->
            <div class="flex-shrink-0 flex items-center gap-4 mb-4 lg:mb-0">
              <div class="number-badge relative z-10">
                {step.num}
              </div>
            </div>

            <!-- Content card -->
            <div class="glass-card glass-card-hover rounded-2xl p-8 flex-1 lg:ml-4">
              <div class="flex flex-col md:flex-row md:items-start gap-6">
                <div class="flex-shrink-0" style="color: var(--color-accent-purple);" set:html={step.icon} />
                <div>
                  <h3 class="text-2xl font-bold mb-3">{step.title}</h3>
                  <p class="text-base leading-relaxed" style="color: var(--color-text-secondary);">
                    {step.description}
                  </p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
