---
---

<section class="section-padding py-20 relative overflow-hidden">
  <div class="mx-auto max-w-5xl">
    <div class="reveal-scale">
      <a href="/crontrepreneur" class="cron-teaser block glass-card rounded-2xl p-8 md:p-12 relative overflow-hidden group transition-all duration-500 hover:border-[rgba(212,132,58,0.25)]">
        <!-- Background glow -->
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none">
          <div class="absolute top-0 right-0 w-64 h-64 rounded-full"
            style="background: radial-gradient(circle, rgba(212, 132, 58, 0.08), transparent 70%); filter: blur(40px);"></div>
        </div>

        <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12 relative z-10">
          <!-- Left: Terminal mini-preview -->
          <div class="flex-shrink-0 w-full md:w-auto">
            <div class="terminal-window rounded-lg" style="width: 280px; max-width: 100%;">
              <div class="terminal-titlebar" style="padding: 8px 12px;">
                <div class="w-2 h-2 rounded-full" style="background: #ff5f57;"></div>
                <div class="w-2 h-2 rounded-full" style="background: #febc2e;"></div>
                <div class="w-2 h-2 rounded-full" style="background: #28c840;"></div>
                <span class="ml-2 text-[9px]" style="color: var(--color-text-muted);">crontrepreneur</span>
              </div>
              <div class="p-3 text-[10px] font-mono" style="line-height: 1.6;">
                <div style="color: #D4A853;">$ crontrepreneur install</div>
                <div style="color: #22c55e;">✓ 14 APIs · 50 crons · 5 engines</div>
                <div style="color: #D4843A; font-weight: 600;">⚡ Operational.</div>
              </div>
            </div>
          </div>

          <!-- Right: Copy -->
          <div class="flex-1 text-center md:text-left">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full mb-4"
              style="background: rgba(212, 132, 58, 0.08); border: 1px solid rgba(212, 132, 58, 0.15);">
              <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background: var(--color-accent-blue);"></span>
              <span class="text-[10px] font-semibold tracking-[0.2em] uppercase" style="color: var(--color-accent-blue);">Coming Soon</span>
            </div>

            <h3 class="text-2xl md:text-3xl font-extrabold tracking-tight mb-3">
              <span class="gradient-text">Crontrepreneur</span>
            </h3>

            <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-secondary);">
              Don't want to build it yourself? Crontrepreneur is the pre-assembled version — 
              one install, fully configured, immediately operational.
            </p>

            <span class="inline-flex items-center gap-1.5 text-xs font-semibold tracking-wider uppercase transition-all duration-300 group-hover:gap-3" style="color: var(--color-accent-blue);">
              Learn More
              <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>
