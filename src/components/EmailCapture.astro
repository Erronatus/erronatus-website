---
---

<section class="section-spacing section-padding relative overflow-hidden">
  <div class="mx-auto max-w-4xl relative">
    <div class="reveal">
      <div class="rounded-3xl p-10 md:p-16 text-center relative overflow-hidden"
        style="background: var(--color-surface); border: 1px solid var(--color-border);">
        <!-- Background gradient -->
        <div class="absolute inset-0 opacity-30">
          <div class="absolute top-0 right-0 w-80 h-80 rounded-full"
            style="background: radial-gradient(circle, rgba(139, 92, 246, 0.3), transparent 70%); filter: blur(60px);">
          </div>
          <div class="absolute bottom-0 left-0 w-60 h-60 rounded-full"
            style="background: radial-gradient(circle, rgba(59, 130, 246, 0.2), transparent 70%); filter: blur(60px);">
          </div>
        </div>

        <div class="relative z-10">
          <span class="text-xs font-semibold tracking-[0.3em] uppercase" style="color: var(--color-accent-purple);">
            Free Weekly Intel
          </span>

          <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight mt-4 mb-4">
            The Automation
            <span class="gradient-text">Dispatch</span>
          </h2>

          <p class="max-w-lg mx-auto text-base mb-10" style="color: var(--color-text-secondary);">
            Weekly breakdown of AI automation strategies, new tools worth your attention,
            and systems that actually make money. No filler. No spam.
          </p>

          <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="return false;">
            <input
              type="email"
              placeholder="your@email.com"
              class="flex-1 px-6 py-4 rounded-full text-sm outline-none transition-all duration-300 focus:ring-2 focus:ring-accent-purple/50"
              style="background: var(--color-bg); border: 1px solid var(--color-border); color: var(--color-text);"
              required
            />
            <button
              type="submit"
              class="btn-primary whitespace-nowrap"
            >
              Subscribe
            </button>
          </form>

          <p class="mt-4 text-xs" style="color: var(--color-text-muted);">
            Join 1,200+ builders. Unsubscribe anytime.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
