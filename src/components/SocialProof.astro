---
---

<section class="section-padding py-16 relative overflow-hidden">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 reveal stagger-children">
      {[
        { value: '250+', label: 'Builders Using The Blueprint', icon: '👥' },
        { value: '24', label: 'Complete Chapters', icon: '📖' },
        { value: '14', label: 'API Integrations', icon: '⚡' },
        { value: '50+', label: 'Cron Templates Included', icon: '⏰' },
      ].map(stat => (
        <div class="text-center reveal">
          <div class="text-3xl mb-3">{stat.icon}</div>
          <div class="text-3xl md:text-4xl font-extrabold gradient-text">{stat.value}</div>
          <div class="text-xs mt-2" style="color: var(--color-text-muted);">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
