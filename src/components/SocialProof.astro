---
---

<section class="relative overflow-hidden" style="padding: 3rem 0; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
  <!-- Ambient line glow top -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[300px] h-[1px] opacity-30"
    style="background: var(--gradient-primary); filter: blur(1px);"></div>

  <div class="section-padding">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 reveal stagger-children">
        {[
          { value: '270', suffix: 'K+', label: 'Words of Documentation' },
          { value: '14', suffix: '+', label: 'API Integrations' },
          { value: '24', suffix: '', label: 'Complete Chapters' },
          { value: '50', suffix: '+', label: 'Cron Templates' },
        ].map((stat, i) => (
          <div class="stat-block text-center group reveal" style={`transition-delay: ${i * 0.08}s;`}>
            <div class="text-4xl md:text-5xl font-extrabold gradient-text mb-2 transition-transform duration-300 group-hover:scale-105">
              <span data-count={stat.value} data-suffix={stat.suffix}>0{stat.suffix}</span>
            </div>
            <div class="text-[11px] font-semibold tracking-[0.15em] uppercase" style="color: var(--color-text-muted);">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
