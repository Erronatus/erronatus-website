---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="OpenClaw Setup Guide — $27 | Erronatus"
  description="The complete copy-paste guide to deploying your AI employee. 10 chapters. Every config block ready to paste. Zero to working AI in one sitting."
>
  <Header />

  <main class="pt-32 pb-20">
    <section class="section-padding">
      <div class="mx-auto max-w-5xl">

        <!-- Hero -->
        <div class="text-center mb-20 reveal">
          <div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full mb-8"
            style="background: rgba(34, 197, 94, 0.08); border: 1px solid rgba(34, 197, 94, 0.15);">
            <span class="w-1.5 h-1.5 rounded-full" style="background: #22c55e;"></span>
            <span class="text-[11px] font-semibold tracking-[0.2em] uppercase" style="color: #22c55e;">
              Instant Download
            </span>
          </div>

          <h1 class="text-[2.5rem] sm:text-[3.5rem] md:text-[4.5rem] font-extrabold tracking-[-0.03em] leading-[0.92] mb-6">
            Deploy Your
            <span class="gradient-text">AI Employee</span>
          </h1>

          <p class="max-w-2xl mx-auto text-xl md:text-2xl leading-relaxed mb-4" style="color: var(--color-text-secondary);">
            The complete OpenClaw setup guide. Copy-paste config. Working AI by end of day.
          </p>

          <p class="max-w-xl mx-auto text-base leading-relaxed mb-8" style="color: var(--color-text-muted);">
            10 chapters. Every command is real. Every config block is ready to paste.
            No prior AI experience required.
          </p>

          <div class="flex items-center justify-center gap-4 mb-12">
            <span class="text-5xl font-extrabold" style="color: var(--color-text);">$27</span>
            <span class="text-sm" style="color: var(--color-text-muted);">one-time<br/>lifetime access</span>
          </div>

          <button
            id="setup-guide-buy"
            class="btn-primary text-base px-10 py-4"
          >
            Get the Setup Guide →
          </button>
        </div>

        <!-- What's Inside -->
        <div class="mb-20 reveal">
          <h2 class="text-2xl font-bold text-center mb-4">What's Inside</h2>
          <p class="text-center text-sm mb-12" style="color: var(--color-text-muted);">
            10 chapters. ~40 pages. Every block is copy-paste ready.
          </p>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {[
              {
                num: '00',
                title: 'Before You Start',
                desc: 'Prerequisites, how to open a terminal, how to edit config files. The foundation chapter that makes everything else click — even if you\'ve never touched a command line.',
                tag: 'Foundation'
              },
              {
                num: '01',
                title: 'Installation',
                desc: 'One-command install for Windows, Mac, and Linux. Verify everything works. Start the gateway. Three commands and you\'re running.',
                tag: 'Setup'
              },
              {
                num: '02',
                title: 'Model Setup',
                desc: 'Connect to Anthropic, OpenAI, OpenRouter, or run free local models with Ollama. Three config templates: budget, power, and premium.',
                tag: 'AI Models'
              },
              {
                num: '03',
                title: 'The Workspace',
                desc: 'Copy-paste templates for SOUL.md, USER.md, AGENTS.md, MEMORY.md, TOOLS.md, and HEARTBEAT.md. Your AI gets identity, memory, and monitoring in one chapter.',
                tag: 'Identity'
              },
              {
                num: '04',
                title: 'Channel Setup',
                desc: 'Connect Telegram or Discord. Lock it to your account only — nobody else can message your bot. Step-by-step with security verification.',
                tag: 'Messaging'
              },
              {
                num: '05',
                title: 'Exec & Permissions',
                desc: 'Give your AI hands. Shell access, file management, deployments. Full operator mode with safety rails and elevated permissions locked to your ID.',
                tag: 'Permissions'
              },
              {
                num: '06',
                title: 'Sub-Agents',
                desc: 'Background workers your AI dispatches for parallel tasks. Research, builds, and analysis running simultaneously while you keep chatting.',
                tag: 'Workers'
              },
              {
                num: '07',
                title: 'Cron Jobs',
                desc: '5 ready-to-paste scheduled jobs: health checks, revenue reports, content calendars, competitor monitoring, and memory maintenance.',
                tag: 'Automation'
              },
              {
                num: '08',
                title: 'Troubleshooting',
                desc: 'The 5-level fix ladder: from restart to nuclear reinstall. Every common error with the exact fix. Platform-specific service removal.',
                tag: 'Repair'
              },
            ].map((item) => (
              <div class="glass-card glass-card-hover rounded-xl p-6">
                <div class="flex items-center gap-3 mb-4">
                  <span class="text-xs font-mono font-bold px-2 py-0.5 rounded"
                    style="background: rgba(212, 132, 58, 0.1); color: var(--color-accent-blue);">
                    {item.num}
                  </span>
                  <span class="text-[10px] font-semibold tracking-wider uppercase px-2 py-0.5 rounded-full"
                    style="background: rgba(123, 143, 168, 0.1); color: var(--color-accent-cyan);">
                    {item.tag}
                  </span>
                </div>
                <h3 class="text-base font-bold mb-2">{item.title}</h3>
                <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{item.desc}</p>
              </div>
            ))}

            <!-- Complete Config card -->
            <div class="glass-card rounded-xl p-6 relative overflow-hidden"
              style="background: rgba(212, 132, 58, 0.04); border: 1px solid rgba(212, 132, 58, 0.15);">
              <div class="absolute top-3 right-3">
                <span class="text-[10px] font-bold tracking-wider uppercase px-2 py-0.5 rounded-full"
                  style="background: rgba(212, 168, 83, 0.15); color: var(--color-gold);">
                  BONUS
                </span>
              </div>
              <div class="flex items-center gap-3 mb-4">
                <span class="text-xs font-mono font-bold px-2 py-0.5 rounded"
                  style="background: rgba(212, 132, 58, 0.1); color: var(--color-accent-blue);">
                  09
                </span>
                <span class="text-[10px] font-semibold tracking-wider uppercase px-2 py-0.5 rounded-full"
                  style="background: rgba(123, 143, 168, 0.1); color: var(--color-accent-cyan);">
                  Config
                </span>
              </div>
              <h3 class="text-base font-bold mb-2">Complete Config Reference</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
                Every section assembled into one paste-ready config file. Replace 3 values and you have a working AI employee. 30 lines. Done.
              </p>
            </div>
          </div>
        </div>

        <!-- What You'll Have -->
        <div class="mb-20 reveal">
          <div class="glass-card rounded-2xl p-10 md:p-14">
            <h2 class="text-2xl font-bold mb-8 text-center">By End of Day, You'll Have</h2>
            <div class="grid md:grid-cols-2 gap-6">
              {[
                'AI running on your machine — not someone else\'s server',
                'Connected to Telegram or Discord — locked to your account',
                'Identity files that shape how your AI thinks and decides',
                'Memory system that persists between conversations',
                'Full shell access — deploy code, manage files, run scripts',
                'Sub-agents for parallel background work',
                'Scheduled automation — monitoring, reports, reminders',
                'A troubleshooting playbook for when things break',
              ].map((item) => (
                <div class="flex items-start gap-3">
                  <span class="mt-0.5 flex-shrink-0" style="color: #22c55e;">✓</span>
                  <span class="text-sm" style="color: var(--color-text-secondary);">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Who This Is For -->
        <div class="mb-20 reveal">
          <div class="glass-card rounded-2xl p-10 md:p-14">
            <h2 class="text-2xl font-bold mb-8 text-center">Who This Is For</h2>
            <div class="grid md:grid-cols-2 gap-8">
              <div>
                <h3 class="text-sm font-bold mb-4" style="color: #22c55e;">✅ Perfect for you if:</h3>
                <ul class="space-y-3 text-sm" style="color: var(--color-text-secondary);">
                  <li class="flex items-start gap-2"><span style="color: #22c55e;">•</span> You want an AI that works for you 24/7 — not just when you open a chat window</li>
                  <li class="flex items-start gap-2"><span style="color: #22c55e;">•</span> You've never set up a server, terminal, or AI system before</li>
                  <li class="flex items-start gap-2"><span style="color: #22c55e;">•</span> You want copy-paste config, not theory</li>
                  <li class="flex items-start gap-2"><span style="color: #22c55e;">•</span> You're tired of AI chatbots that forget everything and can't do anything</li>
                  <li class="flex items-start gap-2"><span style="color: #22c55e;">•</span> You can follow step-by-step instructions for 45-90 minutes</li>
                </ul>
              </div>
              <div>
                <h3 class="text-sm font-bold mb-4" style="color: #ef4444;">❌ Not for you if:</h3>
                <ul class="space-y-3 text-sm" style="color: var(--color-text-secondary);">
                  <li class="flex items-start gap-2"><span style="color: #ef4444;">•</span> You already have OpenClaw running and configured</li>
                  <li class="flex items-start gap-2"><span style="color: #ef4444;">•</span> You want business automation blueprints (get the <a href="/#blueprint" class="link-hover" style="color: var(--color-accent-blue);">Blueprint</a> instead)</li>
                  <li class="flex items-start gap-2"><span style="color: #ef4444;">•</span> You expect results without doing the setup</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Comparison to Blueprint -->
        <div class="mb-20 reveal">
          <h2 class="text-2xl font-bold text-center mb-8">Setup Guide vs Blueprint</h2>
          <div class="glass-card rounded-xl overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr style="background: rgba(212, 132, 58, 0.05);">
                  <th class="text-left p-4 font-semibold" style="color: var(--color-text-muted);">Feature</th>
                  <th class="text-center p-4 font-bold" style="color: var(--color-accent-blue);">Setup Guide — $27</th>
                  <th class="text-center p-4 font-bold" style="color: var(--color-gold);">Blueprint — from $47</th>
                </tr>
              </thead>
              <tbody style="color: var(--color-text-secondary);">
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">Purpose</td><td class="text-center p-4">Get OpenClaw running</td><td class="text-center p-4">Build automated businesses</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">Pages</td><td class="text-center p-4">~40 pages</td><td class="text-center p-4">236–820 pages</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">Experience needed</td><td class="text-center p-4">None</td><td class="text-center p-4">OpenClaw installed</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">Copy-paste config</td><td class="text-center p-4">✓ Every block</td><td class="text-center p-4">✓ Templates included</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">AI model setup</td><td class="text-center p-4">✓ Cloud + local</td><td class="text-center p-4">✓ Advanced routing</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">Channel security</td><td class="text-center p-4">✓ Locked to your ID</td><td class="text-center p-4">✓ Multi-channel</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">Automation depth</td><td class="text-center p-4">5 starter cron jobs</td><td class="text-center p-4">50+ workflows</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">Revenue systems</td><td class="text-center p-4">—</td><td class="text-center p-4">Full stack</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">API integrations</td><td class="text-center p-4">4 (AI + search)</td><td class="text-center p-4">14+ services</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">Setup time</td><td class="text-center p-4">45-90 minutes</td><td class="text-center p-4">2–4 hours</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-center text-xs mt-4" style="color: var(--color-text-muted);">
            Start with the Setup Guide. Upgrade to the Blueprint when you're ready to build.
          </p>
        </div>

        <!-- CTA -->
        <div class="text-center reveal">
          <div class="glass-card rounded-2xl p-10 md:p-14 max-w-2xl mx-auto relative overflow-hidden">
            <div class="absolute inset-0 opacity-10 pointer-events-none">
              <div class="absolute top-0 right-0 w-60 h-60 rounded-full"
                style="background: radial-gradient(circle, rgba(212, 132, 58, 0.4), transparent 70%); filter: blur(40px);"></div>
            </div>
            <div class="relative z-10">
              <h2 class="text-3xl font-extrabold tracking-tight mb-4">
                Your AI Employee
                <span class="gradient-text">Starts Here</span>
              </h2>
              <p class="text-base mb-2" style="color: var(--color-text-secondary);">
                10 chapters. Copy-paste config. Working AI by end of day.
              </p>
              <p class="text-4xl font-extrabold mb-6" style="color: var(--color-text);">$27</p>
              <button id="setup-guide-buy-bottom" class="btn-primary text-base px-10 py-4">
                Get the Setup Guide →
              </button>
              <p class="mt-6 text-xs" style="color: var(--color-text-muted);">
                🛡️ 30-day money-back guarantee. Instant PDF delivery via email.
              </p>
            </div>
          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var buttons = document.querySelectorAll('#setup-guide-buy, #setup-guide-buy-bottom');
  buttons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      btn.textContent = 'Processing...';
      btn.disabled = true;
      btn.style.opacity = '0.7';

      fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          priceId: 'price_1TAZh2Q9JjxqCgrLxfDTqP8L',
          edition: 'setup-guide'
        })
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        if (data.url) {
          window.location.href = data.url;
        } else {
          btn.textContent = 'Get the Setup Guide →';
          btn.disabled = false;
          btn.style.opacity = '1';
          alert('Something went wrong. Please try again.');
        }
      })
      .catch(function() {
        btn.textContent = 'Get the Setup Guide →';
        btn.disabled = false;
        btn.style.opacity = '1';
        alert('Network error. Please try again.');
      });
    });
  });
});
</script>
