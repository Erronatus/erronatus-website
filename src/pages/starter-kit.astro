---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="AI Automation Starter Kit — $27 | Erronatus"
  description="5 plug-and-play automation scripts + step-by-step guides. Start automating in 30 minutes. No coding experience required."
>
  <Header />

  <main class="pt-32 pb-20">
    <section class="section-padding">
      <div class="mx-auto max-w-5xl">

        <!-- Hero -->
        <div class="text-center mb-20 reveal">
          <div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full mb-8"
            style="background: rgba(34, 197, 94, 0.08); border: 1px solid rgba(34, 197, 94, 0.15);">
            <span class="w-1.5 h-1.5 rounded-full" style="background: #22c55e;"></span>
            <span class="text-[11px] font-semibold tracking-[0.2em] uppercase" style="color: #22c55e;">
              Instant Download
            </span>
          </div>

          <h1 class="text-[2.5rem] sm:text-[3.5rem] md:text-[4.5rem] font-extrabold tracking-[-0.03em] leading-[0.92] mb-6">
            AI Automation
            <span class="gradient-text">Starter Kit</span>
          </h1>

          <p class="max-w-2xl mx-auto text-xl md:text-2xl leading-relaxed mb-4" style="color: var(--color-text-secondary);">
            5 plug-and-play scripts. Zero fluff.
          </p>

          <p class="max-w-xl mx-auto text-base leading-relaxed mb-8" style="color: var(--color-text-muted);">
            Stop reading about automation. Start running it.
            Install in 30 minutes. No coding experience required.
          </p>

          <div class="flex items-center justify-center gap-4 mb-12">
            <span class="text-5xl font-extrabold" style="color: var(--color-text);">$27</span>
            <span class="text-sm" style="color: var(--color-text-muted);">one-time<br/>lifetime access</span>
          </div>

          <button
            id="starter-kit-buy"
            class="btn-primary text-base px-10 py-4"
          >
            Get the Starter Kit →
          </button>
        </div>

        <!-- What's Inside -->
        <div class="mb-20 reveal">
          <h2 class="text-2xl font-bold text-center mb-12">What's Inside</h2>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {[
              {
                num: '01',
                title: 'Daily News Aggregator',
                desc: 'Scrapes top AI/tech news from 5 sources, filters signal from noise, delivers a clean daily digest to your inbox. Set it and forget it.',
                tag: 'Cron Job'
              },
              {
                num: '02',
                title: 'Social Media Auto-Poster',
                desc: 'Generates and schedules content across X/Twitter with built-in voice calibration. Posts when your audience is active. Quality gates prevent spam.',
                tag: 'Automation'
              },
              {
                num: '03',
                title: 'API Health Monitor',
                desc: 'Checks your APIs, websites, and services every hour. Sends instant alerts when something breaks. Tracks uptime history automatically.',
                tag: 'Monitoring'
              },
              {
                num: '04',
                title: 'Lead Capture Pipeline',
                desc: 'Email collection form with auto-tagging, welcome sequences, and simple CRM tracking. Connects to any email provider via API.',
                tag: 'Sales'
              },
              {
                num: '05',
                title: 'Competitor Price Tracker',
                desc: 'Monitors competitor pricing pages daily. Alerts you to changes. Logs historical data for trend analysis. Know before your customers do.',
                tag: 'Intelligence'
              },
            ].map((item) => (
              <div class="glass-card glass-card-hover rounded-xl p-6">
                <div class="flex items-center gap-3 mb-4">
                  <span class="text-xs font-mono font-bold px-2 py-0.5 rounded"
                    style="background: rgba(212, 132, 58, 0.1); color: var(--color-accent-blue);">
                    {item.num}
                  </span>
                  <span class="text-[10px] font-semibold tracking-wider uppercase px-2 py-0.5 rounded-full"
                    style="background: rgba(123, 143, 168, 0.1); color: var(--color-accent-cyan);">
                    {item.tag}
                  </span>
                </div>
                <h3 class="text-base font-bold mb-2">{item.title}</h3>
                <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{item.desc}</p>
              </div>
            ))}

            <!-- Bonus card -->
            <div class="glass-card rounded-xl p-6 relative overflow-hidden"
              style="background: rgba(212, 132, 58, 0.04); border: 1px solid rgba(212, 132, 58, 0.15);">
              <div class="absolute top-3 right-3">
                <span class="text-[10px] font-bold tracking-wider uppercase px-2 py-0.5 rounded-full"
                  style="background: rgba(212, 168, 83, 0.15); color: var(--color-gold);">
                  BONUS
                </span>
              </div>
              <div class="text-2xl mb-3">📋</div>
              <h3 class="text-base font-bold mb-2">Quick-Start Guide</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
                Step-by-step setup instructions for Windows, Mac, and Linux.
                Copy-paste commands. Screenshots. No guessing.
              </p>
            </div>
          </div>
        </div>

        <!-- Who This Is For -->
        <div class="mb-20 reveal">
          <div class="glass-card rounded-2xl p-10 md:p-14">
            <h2 class="text-2xl font-bold mb-8 text-center">Who This Is For</h2>
            <div class="grid md:grid-cols-2 gap-8">
              <div>
                <h3 class="text-sm font-bold mb-4" style="color: #22c55e;">✅ Perfect for you if:</h3>
                <ul class="space-y-3 text-sm" style="color: var(--color-text-secondary);">
                  <li class="flex items-start gap-2"><span style="color: #22c55e;">•</span> You want to automate repetitive tasks but don't know where to start</li>
                  <li class="flex items-start gap-2"><span style="color: #22c55e;">•</span> You've heard about AI automation but haven't built anything yet</li>
                  <li class="flex items-start gap-2"><span style="color: #22c55e;">•</span> You want practical scripts, not theory</li>
                  <li class="flex items-start gap-2"><span style="color: #22c55e;">•</span> You run a business and waste hours on manual processes</li>
                  <li class="flex items-start gap-2"><span style="color: #22c55e;">•</span> You can follow step-by-step instructions</li>
                </ul>
              </div>
              <div>
                <h3 class="text-sm font-bold mb-4" style="color: #ef4444;">❌ Not for you if:</h3>
                <ul class="space-y-3 text-sm" style="color: var(--color-text-secondary);">
                  <li class="flex items-start gap-2"><span style="color: #ef4444;">•</span> You're already running 50+ automated workflows</li>
                  <li class="flex items-start gap-2"><span style="color: #ef4444;">•</span> You want a comprehensive business automation system (get the <a href="/#blueprint" class="link-hover" style="color: var(--color-accent-blue);">Blueprint</a> instead)</li>
                  <li class="flex items-start gap-2"><span style="color: #ef4444;">•</span> You expect magic without doing the setup</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Comparison to Blueprint -->
        <div class="mb-20 reveal">
          <h2 class="text-2xl font-bold text-center mb-8">Starter Kit vs Blueprint</h2>
          <div class="glass-card rounded-xl overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr style="background: rgba(212, 132, 58, 0.05);">
                  <th class="text-left p-4 font-semibold" style="color: var(--color-text-muted);">Feature</th>
                  <th class="text-center p-4 font-bold" style="color: var(--color-accent-blue);">Starter Kit — $27</th>
                  <th class="text-center p-4 font-bold" style="color: var(--color-gold);">Blueprint — from $47</th>
                </tr>
              </thead>
              <tbody style="color: var(--color-text-secondary);">
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">Ready-to-run scripts</td><td class="text-center p-4">5 scripts</td><td class="text-center p-4">50+ templates</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">Step-by-step guide</td><td class="text-center p-4">Quick-start (20 pages)</td><td class="text-center p-4">Full manual (236–820 pages)</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">API integrations</td><td class="text-center p-4">3 APIs</td><td class="text-center p-4">14+ APIs</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">AI model routing</td><td class="text-center p-4">—</td><td class="text-center p-4">5 engines, cost-optimized</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">Trading bot scaffold</td><td class="text-center p-4">—</td><td class="text-center p-4">✓</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">Business automation</td><td class="text-center p-4">Basic</td><td class="text-center p-4">Enterprise-grade</td></tr>
                <tr style="border-top: 1px solid var(--color-border);"><td class="p-4">Setup time</td><td class="text-center p-4">30 minutes</td><td class="text-center p-4">2–4 hours</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- CTA -->
        <div class="text-center reveal">
          <div class="glass-card rounded-2xl p-10 md:p-14 max-w-2xl mx-auto relative overflow-hidden">
            <div class="absolute inset-0 opacity-10 pointer-events-none">
              <div class="absolute top-0 right-0 w-60 h-60 rounded-full"
                style="background: radial-gradient(circle, rgba(212, 132, 58, 0.4), transparent 70%); filter: blur(40px);"></div>
            </div>
            <div class="relative z-10">
              <h2 class="text-3xl font-extrabold tracking-tight mb-4">
                Start Automating
                <span class="gradient-text">Today</span>
              </h2>
              <p class="text-base mb-2" style="color: var(--color-text-secondary);">
                5 scripts. 30 minutes to set up. Lifetime access.
              </p>
              <p class="text-4xl font-extrabold mb-6" style="color: var(--color-text);">$27</p>
              <button id="starter-kit-buy-bottom" class="btn-primary text-base px-10 py-4">
                Get the Starter Kit →
              </button>
              <p class="mt-6 text-xs" style="color: var(--color-text-muted);">
                🛡️ 30-day money-back guarantee. Instant delivery via email.
              </p>
            </div>
          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var buttons = document.querySelectorAll('#starter-kit-buy, #starter-kit-buy-bottom');
  buttons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      btn.textContent = 'Processing...';
      btn.disabled = true;
      btn.style.opacity = '0.7';

      fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          priceId: 'price_1TAZh2Q9JjxqCgrLxfDTqP8L',
          edition: 'starter-kit'
        })
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        if (data.url) {
          window.location.href = data.url;
        } else {
          btn.textContent = 'Get the Starter Kit →';
          btn.disabled = false;
          btn.style.opacity = '1';
          alert('Something went wrong. Please try again.');
        }
      })
      .catch(function() {
        btn.textContent = 'Get the Starter Kit →';
        btn.disabled = false;
        btn.style.opacity = '1';
        alert('Network error. Please try again.');
      });
    });
  });
});
</script>
