---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Thank You"
  description="Thank you for purchasing The Erronatus Blueprint. Your download is ready."
  noindex={true}
>
  <Header />

  <main class="pt-32 pb-20">
    <section class="section-padding">
      <div class="mx-auto max-w-2xl text-center">
        <div class="reveal">
          <!-- Success icon -->
          <div class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-8"
            style="background: var(--gradient-primary);">
            <svg class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>

          <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6">
            <span class="gradient-text">Purchase Confirmed</span>
          </h1>

          <p class="text-lg mb-8" style="color: var(--color-text-secondary);">
            Thank you for purchasing The Erronatus Blueprint. Your guide is being prepared and will be delivered to your email within minutes.
          </p>

          <!-- Download Card -->
          <div class="glass-card rounded-2xl p-8 mb-8 text-left">
            <div class="flex items-start gap-4 mb-6">
              <div class="w-12 h-12 rounded-lg flex items-center justify-center"
                style="background: var(--gradient-primary);">
                <span class="text-white font-extrabold text-xl">E</span>
              </div>
              <div>
                <h3 class="text-lg font-bold">The Erronatus Blueprint</h3>
                <p class="text-sm" style="color: var(--color-text-muted);">Personal & Business Guide to AI Automation</p>
              </div>
            </div>

            <div class="space-y-3 mb-6">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5" style="color: var(--color-accent-blue);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <span class="text-sm" style="color: var(--color-text-secondary);">
                  Check your email for the download link (including spam folder)
                </span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5" style="color: var(--color-accent-blue);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span class="text-sm" style="color: var(--color-text-secondary);">
                  Access granted for lifetime updates
                </span>
              </div>
            </div>

            <button class="btn-primary w-full">
              Download PDF Now
            </button>
          </div>

          <!-- Next Steps -->
          <div class="glass-card rounded-2xl p-8 text-left">
            <h3 class="text-lg font-bold mb-4">Next Steps</h3>
            <div class="space-y-4">
              <div>
                <div class="text-sm font-semibold mb-1" style="color: var(--color-accent-cyan);">1. Read the Setup Guide</div>
                <p class="text-sm" style="color: var(--color-text-secondary);">
                  Start with Chapter 1 to install OpenClaw and configure your AI gateway.
                </p>
              </div>
              <div>
                <div class="text-sm font-semibold mb-1" style="color: var(--color-accent-cyan);">2. Join the Community</div>
                <p class="text-sm" style="color: var(--color-text-secondary);">
                  Business Edition buyers get access to the private Telegram group for support and networking.
                </p>
              </div>
              <div>
                <div class="text-sm font-semibold mb-1" style="color: var(--color-accent-cyan);">3. Build Your First Automation</div>
                <p class="text-sm" style="color: var(--color-text-secondary);">
                  Follow Chapter 3 to set up your first cron job and API integration.
                </p>
              </div>
            </div>
          </div>

          <div class="mt-8">
            <a href="/" class="btn-secondary">
              Back to Home
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>