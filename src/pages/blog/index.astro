---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const categories = ['All', ...new Set(posts.map(p => p.data.category))];
---

<BaseLayout
  title="Blog"
  description="Insights, tutorials, and playbooks on AI automation, trading bots, and digital business systems."
>
  <Header />

  <main class="pt-32 pb-20">
    <!-- Hero -->
    <section class="section-padding mb-16">
      <div class="mx-auto max-w-6xl">
        <span class="text-xs font-semibold tracking-[0.3em] uppercase" style="color: var(--color-accent-cyan);">
          The Blog
        </span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight mt-4 mb-6">
          Insights &
          <span class="gradient-text">Playbooks</span>
        </h1>
        <p class="max-w-2xl text-lg" style="color: var(--color-text-secondary);">
          Deep dives into AI automation, trading systems, and the tools that power autonomous digital businesses.
        </p>
      </div>
    </section>

    <!-- Category Filters -->
    <section class="section-padding mb-12">
      <div class="mx-auto max-w-6xl">
        <div class="flex flex-wrap gap-3">
          {categories.map((cat, i) => (
            <button
              class={`px-4 py-2 rounded-full text-xs font-semibold tracking-wider uppercase transition-all duration-300 ${
                i === 0
                  ? 'text-white'
                  : ''
              }`}
              style={i === 0
                ? 'background: var(--gradient-primary);'
                : `background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text-secondary);`
              }
            >
              {cat}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Posts Grid -->
    <section class="section-padding">
      <div class="mx-auto max-w-6xl">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post, i) => (
            <a href={`/blog/${post.slug}`}
              class="glass-card glass-card-hover rounded-2xl overflow-hidden group reveal"
              style={`transition-delay: ${i * 0.05}s;`}>
              <!-- Image -->
              <div class="aspect-[16/9] relative overflow-hidden">
                {post.data.image ? (
                  <img src={post.data.image} alt={post.data.title}
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy" />
                ) : (
                  <div class="absolute inset-0 transition-transform duration-500 group-hover:scale-105"
                    style={`background: linear-gradient(135deg, hsl(${220 + i * 40}, 60%, 15%), hsl(${240 + i * 40}, 60%, 25%));`} />
                )}
                <div class="absolute top-4 left-4">
                  <span class="px-3 py-1 rounded-full text-[10px] font-semibold tracking-widest uppercase text-white"
                    style="background: rgba(139, 92, 246, 0.8); backdrop-filter: blur(8px);">
                    {post.data.category}
                  </span>
                </div>
              </div>

              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-xs" style="color: var(--color-text-muted);">{post.data.date}</span>
                  <span class="w-1 h-1 rounded-full" style="background: var(--color-text-muted);"></span>
                  <span class="text-xs" style="color: var(--color-text-muted);">{post.data.readTime}</span>
                </div>
                <h2 class="text-lg font-bold mb-3 transition-colors duration-300 group-hover:text-accent-purple leading-snug">
                  {post.data.title}
                </h2>
                <p class="text-sm leading-relaxed line-clamp-3" style="color: var(--color-text-secondary);">
                  {post.data.excerpt}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Newsletter CTA -->
    <section class="section-padding mt-20">
      <div class="mx-auto max-w-3xl text-center">
        <div class="glass-card rounded-2xl p-10 reveal">
          <h2 class="text-2xl font-bold mb-3">Never Miss a Post</h2>
          <p class="text-sm mb-6" style="color: var(--color-text-secondary);">
            Get weekly automation insights delivered to your inbox.
          </p>
          <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="return false;">
            <input
              type="email"
              placeholder="your@email.com"
              class="flex-1 px-5 py-3 rounded-full text-sm outline-none"
              style="background: var(--color-bg); border: 1px solid var(--color-border); color: var(--color-text);"
            />
            <button type="submit" class="btn-primary">Subscribe</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
