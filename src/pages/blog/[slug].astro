---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  type="article"
>
  <Header />

  <main class="pt-32 pb-20">
    <article class="section-padding">
      <div class="mx-auto max-w-6xl">
        <!-- Back button -->
        <a href="/blog" class="inline-flex items-center gap-2 text-sm mb-8 hover:text-white transition-colors duration-300"
          style="color: var(--color-text-muted);">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Blog
        </a>

        <!-- Header -->
        <div class="mb-12">
          <span class="text-xs font-semibold tracking-[0.3em] uppercase" style="color: var(--color-accent-purple);">
            {post.data.category}
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mt-4 mb-6">
            {post.data.title}
          </h1>

          <div class="flex flex-wrap items-center gap-4 text-sm" style="color: var(--color-text-muted);">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <span>{post.data.author}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span>{post.data.date}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{post.data.readTime}</span>
            </div>
          </div>
        </div>

        <div class="grid lg:grid-cols-4 gap-12">
          <!-- Content -->
          <div class="lg:col-span-3">
            <!-- Featured image -->
            <div class="aspect-[21/9] rounded-2xl overflow-hidden mb-12"
              style="border: 1px solid rgba(255,255,255,0.06);">
              {post.data.image ? (
                <img src={post.data.image} alt={post.data.title}
                  class="w-full h-full object-cover"
                  loading="eager" />
              ) : (
                <div class="w-full h-full"
                  style="background: linear-gradient(135deg, hsl(250, 60%, 15%), hsl(270, 60%, 25%));" />
              )}
            </div>

            <!-- Table of Contents (Mobile) -->
            <div class="lg:hidden glass-card rounded-xl p-6 mb-8">
              <h3 class="text-lg font-semibold mb-4">Contents</h3>
              <nav class="space-y-2">
                {headings
                  .filter((h) => h.depth === 2)
                  .map((h) => (
                    <a
                      href={`#${h.slug}`}
                      class="text-sm flex items-center gap-2 transition-colors duration-300 hover:text-white"
                      style="color: var(--color-text-muted);"
                    >
                      <span class="w-1.5 h-1.5 rounded-full bg-accent-purple opacity-50"></span>
                      {h.text}
                    </a>
                  ))}
              </nav>
            </div>

            <!-- Article -->
            <div class="prose-custom">
              <Content />
            </div>

            <!-- Tags -->
            <div class="mt-12 pt-8 border-t" style="border-color: var(--color-border);">
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="px-3 py-1 rounded-full text-xs font-medium"
                    style="background: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border);">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <!-- Email capture within post -->
            <div class="mt-12 glass-card rounded-2xl p-8">
              <div class="text-center">
                <h3 class="text-xl font-bold mb-3">Automation Insights Weekly</h3>
                <p class="text-sm mb-6" style="color: var(--color-text-secondary);">
                  Get deep dives like this delivered to your inbox every Friday.
                </p>
                <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="return false;">
                  <input
                    type="email"
                    placeholder="you@company.com"
                    class="flex-1 px-5 py-3 rounded-full text-sm outline-none"
                    style="background: var(--color-bg); border: 1px solid var(--color-border); color: var(--color-text);"
                  />
                  <button type="submit" class="btn-primary whitespace-nowrap">Subscribe</button>
                </form>
              </div>
            </div>

            <!-- Share -->
            <div class="mt-12">
              <h3 class="text-lg font-semibold mb-4">Share this post</h3>
              <div class="flex items-center gap-3">
                <button class="w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 hover:-translate-y-1"
                  style="border: 1px solid var(--color-border); color: var(--color-text-secondary);"
                  aria-label="Share on X">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                </button>
                <button class="w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 hover:-translate-y-1"
                  style="border: 1px solid var(--color-border); color: var(--color-text-secondary);"
                  aria-label="Share on LinkedIn">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>

          <!-- Table of Contents (Desktop) -->
          <div class="lg:col-span-1">
            <div class="sticky top-32 glass-card rounded-xl p-6">
              <h3 class="text-lg font-semibold mb-4">Contents</h3>
              <nav class="space-y-2">
                {headings
                  .filter((h) => h.depth === 2)
                  .map((h) => (
                    <a
                      href={`#${h.slug}`}
                      class="text-sm flex items-center gap-2 py-2 transition-colors duration-300 hover:text-white"
                      style="color: var(--color-text-muted);"
                    >
                      <span class="w-1.5 h-1.5 rounded-full bg-accent-purple opacity-50"></span>
                      {h.text}
                    </a>
                  ))}
              </nav>
            </div>
          </div>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* Smooth scrolling for anchor links */
  html {
    scroll-behavior: smooth;
  }
</style>