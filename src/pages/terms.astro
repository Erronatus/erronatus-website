---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Terms of Service" description="Erronatus Terms of Service — terms governing use of our website and digital products." noindex={true}>
  <Header />
  <main class="pt-32 pb-20">
    <article class="section-padding">
      <div class="mx-auto max-w-3xl prose-custom">
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">Terms of Service</h1>
        <p class="text-sm mb-12" style="color: var(--color-text-muted);">Last updated: March 1, 2026</p>

        <p>These Terms of Service ("Terms") govern your use of erronatus.com ("Website") and the purchase of digital products ("Products") offered by Erronatus ("we," "us," or "our"). By accessing the Website or purchasing Products, you agree to these Terms.</p>

        <h2>1. Products and Services</h2>
        <p>Erronatus sells digital educational products, including PDF guides and related digital assets ("The Erronatus Blueprint"). Products are delivered electronically via email after purchase.</p>

        <h3>Product Editions</h3>
        <ul>
          <li><strong>Personal Edition ($47):</strong> Licensed for individual, personal use only.</li>
          <li><strong>Business Edition ($97):</strong> Licensed for individual or single-business use.</li>
          <li><strong>Enterprise Edition ($299):</strong> Licensed for individual or single-organization use, including pre-built automation workspace and priority support.</li>
