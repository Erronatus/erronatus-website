---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with the Erronatus team. Support, questions, partnerships — we're here."
>
  <Header />

  <main class="pt-32 pb-20">
    <section class="section-padding">
      <div class="mx-auto max-w-4xl">
        <div class="text-center mb-16 reveal">
          <span class="text-xs font-semibold tracking-[0.3em] uppercase" style="color: var(--color-accent-cyan);">
            Contact
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mt-4 mb-6">
            Get In
            <span class="gradient-text">Touch</span>
          </h1>
          <p class="max-w-xl mx-auto text-lg" style="color: var(--color-text-secondary);">
            Question about the Blueprint? Need support? Want to work together? We respond within 24 hours.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-12 lg:gap-16">
          <!-- Contact Form -->
          <div class="reveal-left">
            <form class="space-y-5" id="contact-form">
              <div>
                <label class="block text-xs font-semibold tracking-wider uppercase mb-2" style="color: var(--color-text-muted);">Name</label>
                <input type="text" name="name" required
                  class="w-full px-5 py-3.5 rounded-xl text-sm outline-none transition-all duration-300 focus:ring-2"
                  style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text); --tw-ring-color: rgba(212, 132, 58, 0.3);"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label class="block text-xs font-semibold tracking-wider uppercase mb-2" style="color: var(--color-text-muted);">Email</label>
                <input type="email" name="email" required
                  class="w-full px-5 py-3.5 rounded-xl text-sm outline-none transition-all duration-300 focus:ring-2"
                  style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text); --tw-ring-color: rgba(212, 132, 58, 0.3);"
                  placeholder="your@email.com"
                />
              </div>
              <div>
                <label class="block text-xs font-semibold tracking-wider uppercase mb-2" style="color: var(--color-text-muted);">Subject</label>
                <select name="subject" required
                  class="w-full px-5 py-3.5 rounded-xl text-sm outline-none transition-all duration-300 focus:ring-2"
                  style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text); --tw-ring-color: rgba(212, 132, 58, 0.3);">
                  <option value="" disabled selected>Choose a topic</option>
                  <option value="support">Blueprint Support</option>
                  <option value="refund">Refund Request</option>
                  <option value="question">Pre-Purchase Question</option>
                  <option value="partnership">Partnership / Collaboration</option>
                  <option value="other">Something Else</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold tracking-wider uppercase mb-2" style="color: var(--color-text-muted);">Message</label>
                <textarea name="message" rows="5" required
                  class="w-full px-5 py-3.5 rounded-xl text-sm outline-none transition-all duration-300 resize-none focus:ring-2"
                  style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text); --tw-ring-color: rgba(212, 132, 58, 0.3);"
                  placeholder="Tell us what's on your mind..."
                ></textarea>
              </div>
              <button type="submit" class="btn-primary w-full gap-2">
                <span class="btn-label">Send Message</span>
                <svg class="btn-arrow w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
                <svg class="btn-spinner hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
                </svg>
              </button>
            </form>
          </div>

          <!-- Info Cards -->
          <div class="reveal-right space-y-6">
            <div class="glass-card glass-card-hover rounded-xl p-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
                  style="background: rgba(212, 132, 58, 0.1); border: 1px solid rgba(212, 132, 58, 0.15);">
                  <svg class="w-5 h-5" style="color: var(--color-accent-blue);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-sm font-bold mb-1">Email</h3>
                  <a href="mailto:hello@erronatus.com" class="text-sm link-hover" style="color: var(--color-accent-blue);">
                    hello@erronatus.com
                  </a>
                  <p class="text-xs mt-1" style="color: var(--color-text-muted);">We respond within 24 hours</p>
                </div>
              </div>
            </div>

            <div class="glass-card glass-card-hover rounded-xl p-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
                  style="background: rgba(212, 132, 58, 0.1); border: 1px solid rgba(212, 132, 58, 0.15);">
                  <svg class="w-5 h-5" style="color: var(--color-accent-blue);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-sm font-bold mb-1">Community</h3>
                  <a href="https://discord.com/invite/clawd" target="_blank" rel="noopener noreferrer" class="text-sm link-hover" style="color: var(--color-accent-blue);">
                    Join the Discord
                  </a>
                  <p class="text-xs mt-1" style="color: var(--color-text-muted);">Chat with other builders</p>
                </div>
              </div>
            </div>

            <div class="glass-card glass-card-hover rounded-xl p-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
                  style="background: rgba(212, 132, 58, 0.1); border: 1px solid rgba(212, 132, 58, 0.15);">
                  <svg class="w-5 h-5" style="color: var(--color-accent-blue);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-sm font-bold mb-1">Refunds</h3>
                  <p class="text-sm" style="color: var(--color-text-secondary);">30-day money-back guarantee</p>
                  <p class="text-xs mt-1" style="color: var(--color-text-muted);">No questions asked — just email us</p>
                </div>
              </div>
            </div>

            <div class="glass-card rounded-xl p-6" style="background: rgba(212, 132, 58, 0.04); border: 1px solid rgba(212, 132, 58, 0.1);">
              <h3 class="text-sm font-bold mb-2">Enterprise Support</h3>
              <p class="text-xs leading-relaxed" style="color: var(--color-text-secondary);">
                Enterprise Edition buyers get 90-day priority Telegram support.
                Check your purchase email for the direct line.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var form = document.getElementById('contact-form');
  if (!form) return;

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var btn = form.querySelector('button[type="submit"]');
    var label = btn.querySelector('.btn-label');
    var arrow = btn.querySelector('.btn-arrow');
    var spinner = btn.querySelector('.btn-spinner');

    label.textContent = 'Sending...';
    arrow.classList.add('hidden');
    spinner.classList.remove('hidden');
    btn.disabled = true;
    btn.style.opacity = '0.7';

    var formData = new FormData(form);
    var payload = {
      name: formData.get('name'),
      email: formData.get('email'),
      subject: formData.get('subject'),
      message: formData.get('message')
    };

    fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    .then(function(res) { return res.json().then(function(d) { return { ok: res.ok, data: d }; }); })
    .then(function(result) {
      if (result.ok) {
        form.innerHTML = '<div class="text-center py-12"><div class="text-4xl mb-4">✓</div><h3 class="text-xl font-bold mb-2">Message Sent</h3><p class="text-sm" style="color: var(--color-text-secondary);">We\'ll get back to you within 24 hours.</p></div>';
      } else {
        label.textContent = 'Send Message';
        arrow.classList.remove('hidden');
        spinner.classList.add('hidden');
        btn.disabled = false;
        btn.style.opacity = '1';
        alert(result.data.error || 'Failed to send. Please email hello@erronatus.com directly.');
      }
    })
    .catch(function() {
      label.textContent = 'Send Message';
      arrow.classList.remove('hidden');
      spinner.classList.add('hidden');
      btn.disabled = false;
      btn.style.opacity = '1';
      alert('Network error. Please email hello@erronatus.com directly.');
    });
  });
});
</script>
